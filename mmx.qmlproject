import QmlProject 1.3

Project {
    mainFile: "Main.qml"

    /* Include all QML files in the current directory */
    QmlFiles {
        directory: "."
    }

    /* Include all images/assets in the current directory */
    JavaScriptFiles {
        directory: "."
    }

    ImageFiles {
        directory: "."
    }

    /* Import paths for modules */
    importPaths: [ "." ]
}
